<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:ns1="http://schemas.android.com/tools">
    <color name="bg_base">#0B1014</color>
    <color name="bg_surface">#121A22</color>
    <color name="bg_surface_alt">#1A2530</color>
    <color name="black">#000000</color>
    <color name="brand_primary">#2EC4B6</color>
    <color name="brand_primary_container">#194D4A</color>
    <color name="brand_secondary">#FF9F1C</color>
    <color name="brand_secondary_container">#5A3C12</color>
    <color name="text_on_brand">#071315</color>
    <color name="text_primary">#EAF2F8</color>
    <color name="text_secondary">#B3C1CC</color>
    <color name="white">#FFFFFF</color>
    <string name="app_name">DashcamAI</string>
    <style name="Theme.DashcamAI" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/text_on_brand</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container</item>

        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/text_on_brand</item>
        <item name="colorSecondaryContainer">@color/brand_secondary_container</item>

        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorSurfaceVariant">@color/bg_surface_alt</item>
        <item name="android:colorBackground">@color/bg_base</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:windowBackground">@color/bg_base</item>

        <item name="android:statusBarColor" ns1:targetApi="l">@color/bg_base</item>
        <item name="android:navigationBarColor" ns1:targetApi="o_mr1">@color/bg_base</item>
    </style>
